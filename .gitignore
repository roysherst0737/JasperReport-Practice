
---

# 📦 .gitignore（Jasper + IntelliJ + Maven 完整版）

```gitignore
# ========================
# IntelliJ
# ========================
.idea/
*.iml

# ========================
# Maven
# ========================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next

# ========================
# OS
# ========================
.DS_Store
Thumbs.db

# ========================
# Logs
# ========================
*.log

# ========================
# JasperReports
# ========================
*.jasper

# ========================
# Temp / cache
# ========================
*.tmp
*.temp
*.cache

# ========================
# Output PDF (不要上傳產物)
# ========================
*.pdf
jasperResults/

# ========================
# Eclipse / Jaspersoft Studio
# ========================
.project
.classpath
.settings/

# ========================
# VSCode
# ========================
.vscode/

# ========================
# Fonts（如果你不想上傳字型）
# ========================
# src/main/resources/fonts/*.ttf

# ========================
# Vue / Vite
# ========================
node_modules/
dist/
dist-ssr/
*.local

# ========================
# Env files（敏感資訊）
# ========================
.env
.env.*
!.env.example

# ========================
# Vite cache
# ========================
.vite/

# ========================
# Logs（Node）
# ========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# IDE（前端常見）
# ========================
*.swp
*.swo